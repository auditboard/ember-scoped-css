{
  "name": "vite-app-monorepo-test-app",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "dist:ember:test": "ember test --path dist --config-file ./testem.cjs --test-port 0",
    "lint:js": "eslint . --config ../eslint.config.mjs --cache",
    "lint:js:fix": "eslint . --config ../eslint.config.mjs --fix",
    "test:ember": "vite build --mode test && pnpm dist:ember:test"
  },
  "type": "module",
  "imports": {
    "#src/*": "./src/*"
  },
  "exports": {
    "./tests/*": "./tests/*",
    "./*": "./src/*"
  },
  "dependencies": {
    "@glimmer/component": "2.0.0",
    "ember-resolver": "13.1.0",
    "ember-scoped-css": "workspace:*",
    "ember-source": "6.4.0-alpha.3",
    "vite-app-monorepo-app-other": "workspace:*",
    "vite-app-monorepo-app": "workspace:*"
  },
  "devDependencies": {
    "@babel/core": "7.28.5",
    "@babel/plugin-transform-runtime": "7.28.5",
    "@babel/plugin-transform-typescript": "7.28.5",
    "@babel/runtime": "7.28.4",
    "@ember/test-helpers": "5.2.1",
    "@ember/test-waiters": "4.1.0",
    "@embroider/core": "4.0.1",
    "@embroider/macros": "1.17.1",
    "@embroider/vite": "1.0.2",
    "@rollup/plugin-babel": "6.1.0",
    "babel-plugin-ember-template-compilation": "2.4.1",
    "decorator-transforms": "2.3.0",
    "ember-cli": "6.3.1",
    "ember-qunit": "9.0.2",
    "eslint": "9.36.0",
    "qunit": "3.0.0-alpha.4",
    "qunit-dom": "3.4.0",
    "typescript": "5.7.3",
    "vite": "6.2.5"
  },
  "engines": {
    "node": ">= 22.16"
  },
  "ember": {
    "edition": "octane"
  },
  "ember-addon": {
    "type": "app",
    "version": 2
  }
}
